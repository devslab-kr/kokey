{
  "name": "@devslab/kokey",
  "version": "0.3.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Korean ↔ English keyboard layout converter (Dubeolsik ↔ QWERTY). TypeScript-first, zero-dependency, ESM/CJS dual.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/kokey.global.js",
  "jsdelivr": "./dist/kokey.global.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js",
      "require": "./dist/vue.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "vue": "^3.3.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "jsdom": "^26.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9",
    "vue": "^3.5.13"
  },
  "keywords": [
    "hangul",
    "korean",
    "keyboard",
    "layout",
    "qwerty",
    "dubeolsik",
    "ime",
    "converter",
    "inko",
    "한글",
    "두벌식",
    "한영변환"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devslab-kr/kokey.git"
  },
  "homepage": "https://github.com/devslab-kr/kokey#readme",
  "bugs": {
    "url": "https://github.com/devslab-kr/kokey/issues"
  },
  "author": "devslab <jlc488@gmail.com>",
  "license": "MIT"
}
